---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const u = (path: string) => `${base}${path}`;
---

<Layout title="Contact" description="Get in touch with Kiwi Paws Home Vet. Call, text, or email Nicole for home vet visits across Hamilton and the greater Waikato region.">

  <!-- Header -->
  <div class="wood-bg py-16 md:py-20 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
        Contact Us
      </h1>
      <p class="text-white/85 text-lg">Interested in more information or booking an appointment? We'd love to hear from you.</p>
    </div>
  </div>

  <section class="py-16 md:py-20" style="background-color: #f5f0e4;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-12">

        <!-- Contact Info -->
        <div class="lg:col-span-2 space-y-6">
          <div>
            <h2 class="text-2xl font-bold text-[#2c1a0e] mb-6" style="font-family: 'Playfair Display', Georgia, serif;">Get in Touch</h2>

            <div class="space-y-5">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #e8ede4;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6b8c5a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.9 1.2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9a16 16 0 0 0 6.91 6.91l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-[#2c1a0e]">Phone / Text</p>
                  <a href="tel:021956242" class="text-[#6b8c5a] hover:underline font-medium">021 956 242</a>
                  <p class="text-xs text-[#6b4c2a] mt-0.5">Mon–Fri 9am–5pm</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #e8ede4;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6b8c5a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-[#2c1a0e]">Email</p>
                  <a href="mailto:info@kiwipawshomevet.co.nz" class="text-[#6b8c5a] hover:underline font-medium text-sm">info@kiwipawshomevet.co.nz</a>
                  <p class="text-xs text-[#6b4c2a] mt-0.5">Any time — we'll reply within 24 hours</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #e8ede4;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6b8c5a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-[#2c1a0e]">Service Area</p>
                  <p class="text-[#6b4c2a]">Hamilton &amp; greater Waikato</p>
                  <p class="text-xs text-[#6b4c2a] mt-0.5">New Zealand</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background-color: #e8ede4;">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6b8c5a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
                  </svg>
                </div>
                <div>
                  <p class="font-semibold text-[#2c1a0e]">Instagram</p>
                  <a href="https://www.instagram.com/KiwiPawsHomeVet" target="_blank" rel="noopener noreferrer" class="text-[#6b8c5a] hover:underline font-medium">@KiwiPawsHomeVet</a>
                </div>
              </div>
            </div>
          </div>

          <!-- Notice box -->
          <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
            <p class="font-semibold text-amber-800 text-sm mb-1">🚨 Not an emergency service</p>
            <p class="text-amber-700 text-xs leading-relaxed">For after-hours emergencies, please contact your nearest emergency veterinary clinic.</p>
          </div>

          <!-- Image -->
          <img
            src="https://images.squarespace-cdn.com/content/v1/69914e60b1210a495133a353/434d48d0-15b6-41b8-8ddf-efee84217065/IMG_4828.jpg"
            alt="Kiwi Paws Home Vet"
            class="w-full rounded-2xl shadow-sm object-cover"
            style="max-height: 280px;"
          />
        </div>

        <!-- Contact Form -->
        <div class="lg:col-span-3">
          <div class="bg-white rounded-2xl shadow-sm p-8">
            <h2 class="text-2xl font-bold text-[#2c1a0e] mb-2" style="font-family: 'Playfair Display', Georgia, serif;">Send Us a Message</h2>
            <p class="text-[#6b4c2a] text-sm mb-6">Fill in the form below and Nicole will get back to you within 24 hours.</p>

            <form
              action="https://formspree.io/f/REPLACE_WITH_YOUR_FORMSPREE_ID"
              method="POST"
              id="contact-form"
              class="space-y-5"
            >
              <input type="hidden" name="_subject" value="New contact from Kiwi Paws Home Vet website" />
              <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="name" class="form-label">Your Name <span class="text-red-500">*</span></label>
                  <input type="text" id="name" name="name" required class="form-input" placeholder="Jane Smith" />
                </div>
                <div>
                  <label for="phone" class="form-label">Phone Number</label>
                  <input type="tel" id="phone" name="phone" class="form-input" placeholder="021 234 567" />
                </div>
              </div>

              <div>
                <label for="email" class="form-label">Email Address <span class="text-red-500">*</span></label>
                <input type="email" id="email" name="email" required class="form-input" placeholder="jane@example.com" />
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                <div>
                  <label for="pet-name" class="form-label">Pet's Name</label>
                  <input type="text" id="pet-name" name="pet_name" class="form-input" placeholder="Fluffy" />
                </div>
                <div>
                  <label for="pet-type" class="form-label">Type of Pet</label>
                  <select id="pet-type" name="pet_type" class="form-input">
                    <option value="">Select...</option>
                    <option>Dog</option>
                    <option>Cat</option>
                    <option>Rabbit</option>
                    <option>Other</option>
                  </select>
                </div>
              </div>

              <div>
                <label for="message" class="form-label">Message <span class="text-red-500">*</span></label>
                <textarea id="message" name="message" required rows="5" class="form-input resize-none" placeholder="Tell us about your pet and how we can help..."></textarea>
              </div>

              <div id="form-success" class="hidden bg-green-50 border border-green-200 rounded-xl p-4 text-green-800 text-sm">
                Thanks for your message! Nicole will be in touch within 24 hours.
              </div>
              <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-red-800 text-sm">
                Something went wrong. Please try again or email us directly at info@kiwipawshomevet.co.nz
              </div>

              <div class="flex items-center gap-4">
                <button type="submit" class="btn-primary">
                  Send Message
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"/><path d="M22 2 11 13"/></svg>
                </button>
                <p class="text-xs text-[#6b4c2a]">Or call <a href="tel:021956242" class="text-[#6b8c5a] hover:underline font-medium">021 956 242</a></p>
              </div>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' }
      });
      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
        error?.classList.add('hidden');
      } else {
        throw new Error();
      }
    } catch {
      error?.classList.remove('hidden');
      success?.classList.add('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
