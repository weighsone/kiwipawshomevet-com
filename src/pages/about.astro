---
import Layout from '../layouts/Layout.astro';
---

<Layout title="About Nicole" description="Meet Nicole, Kiwi Paws Home Vet's passionate veterinarian with over 10 years of experience in companion animal care across Hamilton and Waikato, NZ.">

  <!-- Header -->
  <div class="wood-bg py-16 md:py-20 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
        About Nicole
      </h1>
      <p class="text-white/85 text-lg">Your dedicated home veterinarian in Hamilton &amp; the Waikato</p>
    </div>
  </div>

  <!-- Main About -->
  <section class="py-16 md:py-20" style="background-color: #f5f0e4;">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center mb-16">
        <div>
          <img
            src="https://images.squarespace-cdn.com/content/v1/69914e60b1210a495133a353/8e867c82-bd46-4b50-a330-c0cd0adbeead/IMG_2742.jpeg"
            alt="Nicole, veterinarian at Kiwi Paws Home Vet"
            class="w-full rounded-2xl shadow-lg object-cover"
            style="max-height: 520px;"
          />
        </div>
        <div>
          <p class="text-[#6b8c5a] font-semibold uppercase tracking-wide text-sm mb-2">Meet Your Vet</p>
          <h2 class="text-3xl font-bold text-[#2c1a0e] mb-5" style="font-family: 'Playfair Display', Georgia, serif;">
            Nicole — Companion Animal Veterinarian
          </h2>
          <p class="text-[#6b4c2a] leading-relaxed mb-4">
            Nicole is a companion animal veterinarian with over 10 years of experience. She is deeply passionate about creating calm, positive veterinary experiences for pets and their families.
          </p>
          <p class="text-[#6b4c2a] leading-relaxed mb-4">
            After years of working in busy clinical environments, Nicole noticed how stressful traditional vet visits could be for many animals — particularly anxious dogs, cats who hate carriers, and elderly pets for whom travel is difficult. She founded Kiwi Paws Home Vet to solve this: bringing professional, thorough care directly to pets in their own homes.
          </p>
          <p class="text-[#6b4c2a] leading-relaxed mb-6">
            Nicole focuses on preventative care plans tailored to each individual animal, taking the time to truly understand your pet's health history, lifestyle, and needs. When she's not working, she spends time with her daughter and her beloved large white cat, Professor Dumbledore.
          </p>

          <div class="grid grid-cols-2 gap-4 mb-8">
            <div class="bg-white rounded-xl p-4 text-center">
              <p class="text-2xl font-bold text-[#6b8c5a]" style="font-family: 'Playfair Display', Georgia, serif;">10+</p>
              <p class="text-sm text-[#6b4c2a]">Years experience</p>
            </div>
            <div class="bg-white rounded-xl p-4 text-center">
              <p class="text-2xl font-bold text-[#6b8c5a]" style="font-family: 'Playfair Display', Georgia, serif;">Waikato</p>
              <p class="text-sm text-[#6b4c2a]">Region-wide service</p>
            </div>
          </div>

          <a href="/book" class="btn-primary">Book a Home Visit</a>
        </div>
      </div>

      <!-- Philosophy -->
      <div class="bg-white rounded-2xl p-8 md:p-12 mb-12">
        <h2 class="text-2xl font-bold text-[#2c1a0e] mb-6 text-center" style="font-family: 'Playfair Display', Georgia, serif;">
          Our Care Philosophy
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {[
            {
              title: 'Stress-Free Visits',
              body: 'Pets are naturally more relaxed in their home environment. By coming to you, Nicole can provide more accurate assessments and a calmer experience for anxious or elderly animals.'
            },
            {
              title: 'No Time Pressure',
              body: 'Unlike busy clinics, home visits mean Nicole can take all the time needed to answer your questions, examine your pet thoroughly, and create a complete care plan.'
            },
            {
              title: 'Preventative Focus',
              body: 'Nicole believes prevention is always better than cure. Every visit includes a tailored preventative care plan to keep your pet healthy for years to come.'
            },
          ].map(p => (
            <div class="text-center">
              <div class="paw-icon mx-auto mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#6b8c5a" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                </svg>
              </div>
              <h3 class="font-bold text-[#2c1a0e] mb-2">{p.title}</h3>
              <p class="text-sm text-[#6b4c2a] leading-relaxed">{p.body}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Second image -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center">
        <div>
          <h2 class="text-2xl font-bold text-[#2c1a0e] mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
            Who We Care For
          </h2>
          <p class="text-[#6b4c2a] leading-relaxed mb-4">
            Kiwi Paws Home Vet cares for dogs, cats, rabbits, and other small companion animals. Whether you need a routine wellness check, vaccinations, management of an ongoing condition, or end-of-life care, Nicole provides comprehensive services tailored to your pet.
          </p>
          <ul class="space-y-2 mb-6">
            {[
              'Dogs (all sizes and breeds)',
              'Cats — especially those who hate carriers',
              'Rabbits and small mammals',
              'Senior and palliative care patients',
              'Anxious or fearful animals',
              'Multi-pet households',
            ].map(item => (
              <li class="flex items-center gap-2 text-[#6b4c2a] text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#6b8c5a" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div>
          <img
            src="https://images.squarespace-cdn.com/content/v1/69914e60b1210a495133a353/4b3e5224-9463-4901-b003-87c2f88a1283/IMG_2192.jpeg"
            alt="Kiwi Paws Home Vet caring for pets"
            class="w-full rounded-2xl shadow-lg object-cover"
            style="max-height: 380px;"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-12 text-center" style="background-color: #6b8c5a;">
    <div class="max-w-xl mx-auto px-4">
      <h2 class="text-2xl font-bold text-white mb-3" style="font-family: 'Playfair Display', Georgia, serif;">Ready to meet Nicole?</h2>
      <p class="text-white/90 mb-6">Book a home visit and see the difference stress-free vet care can make.</p>
      <a href="/book" class="btn-primary" style="background-color: white; color: #6b8c5a;">Book a Home Visit</a>
    </div>
  </section>

</Layout>
