---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const u = (path: string) => `${base}${path}`;
---

<Layout title="Book a Home Visit" description="Book a home vet visit with Kiwi Paws Home Vet. Serving Hamilton and the greater Waikato region, New Zealand.">

  <!-- Header -->
  <div class="wood-bg py-16 md:py-20 text-center">
    <div class="max-w-3xl mx-auto px-4">
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4" style="font-family: 'Playfair Display', Georgia, serif;">
        Book a Home Visit
      </h1>
      <p class="text-white/85 text-lg">Tell us about your pet and we'll be in touch to confirm your appointment.</p>
    </div>
  </div>

  <section class="py-16 md:py-20" style="background-color: #f5f0e4;">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

        <!-- Sidebar info -->
        <div class="space-y-6">
          <div class="bg-white rounded-2xl p-6 shadow-sm">
            <h3 class="font-bold text-[#2c1a0e] mb-4" style="font-family: 'Playfair Display', Georgia, serif;">What to Expect</h3>
            <ol class="space-y-3">
              {[
                'Fill in the booking form',
                'Nicole confirms your appointment via phone or email',
                'Vet visits your home at the agreed time',
                'Pay by EFTPOS or bank transfer on the day',
              ].map((step, i) => (
                <li class="flex items-start gap-3 text-sm text-[#6b4c2a]">
                  <span class="w-6 h-6 rounded-full flex items-center justify-center text-xs font-bold text-white shrink-0 mt-0.5" style="background-color: #6b8c5a;">{i + 1}</span>
                  {step}
                </li>
              ))}
            </ol>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm">
            <h3 class="font-bold text-[#2c1a0e] mb-3" style="font-family: 'Playfair Display', Georgia, serif;">Quick Pricing</h3>
            <ul class="space-y-2 text-sm text-[#6b4c2a]">
              <li class="flex justify-between"><span>Routine Consultation</span><span class="font-semibold text-[#6b8c5a]">$150</span></li>
              <li class="flex justify-between"><span>Additional pet</span><span class="font-semibold text-[#6b8c5a]">+$100</span></li>
              <li class="flex justify-between"><span>Recheck</span><span class="font-semibold text-[#6b8c5a]">$120</span></li>
              <li class="flex justify-between"><span>Telemedicine</span><span class="font-semibold text-[#6b8c5a]">$80</span></li>
              <li class="flex justify-between"><span>Vaccinations (add-on)</span><span class="font-semibold text-[#6b8c5a]">from $40</span></li>
              <li class="flex justify-between"><span>End-of-life care</span><span class="font-semibold text-[#6b8c5a]">from $400</span></li>
            </ul>
            <a href={u("/services")} class="text-[#6b8c5a] text-xs hover:underline mt-3 block">View full pricing →</a>
          </div>

          <div class="bg-white rounded-2xl p-6 shadow-sm">
            <h3 class="font-bold text-[#2c1a0e] mb-3" style="font-family: 'Playfair Display', Georgia, serif;">Prefer to Call?</h3>
            <p class="text-sm text-[#6b4c2a] mb-3">Call or text Nicole directly to book.</p>
            <a href="tel:021956242" class="btn-primary text-sm w-full justify-center">
              021 956 242
            </a>
            <p class="text-xs text-[#6b4c2a] mt-2 text-center">Mon–Fri 9am–5pm</p>
          </div>

          <div class="bg-amber-50 border border-amber-200 rounded-xl p-4">
            <p class="font-semibold text-amber-800 text-sm mb-1">🚨 Not an emergency service</p>
            <p class="text-amber-700 text-xs leading-relaxed">For emergencies please contact your nearest emergency veterinary clinic.</p>
          </div>
        </div>

        <!-- Booking Form -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-2xl shadow-sm p-8">
            <h2 class="text-2xl font-bold text-[#2c1a0e] mb-2" style="font-family: 'Playfair Display', Georgia, serif;">Booking Request</h2>
            <p class="text-[#6b4c2a] text-sm mb-6">Complete the form below and Nicole will confirm your appointment within 24 hours.</p>

            <form
              action="https://formspree.io/f/REPLACE_WITH_YOUR_FORMSPREE_ID"
              method="POST"
              id="booking-form"
              class="space-y-5"
            >
              <input type="hidden" name="_subject" value="New booking request — Kiwi Paws Home Vet" />
              <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

              <!-- Owner details -->
              <div>
                <h3 class="font-semibold text-[#2c1a0e] text-sm uppercase tracking-wide mb-3">Your Details</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="owner-name" class="form-label">Full Name <span class="text-red-500">*</span></label>
                    <input type="text" id="owner-name" name="owner_name" required class="form-input" placeholder="Jane Smith" />
                  </div>
                  <div>
                    <label for="owner-phone" class="form-label">Phone <span class="text-red-500">*</span></label>
                    <input type="tel" id="owner-phone" name="owner_phone" required class="form-input" placeholder="021 234 567" />
                  </div>
                </div>
              </div>

              <div>
                <label for="owner-email" class="form-label">Email Address <span class="text-red-500">*</span></label>
                <input type="email" id="owner-email" name="owner_email" required class="form-input" placeholder="jane@example.com" />
              </div>

              <div>
                <label for="address" class="form-label">Home Address / Suburb <span class="text-red-500">*</span></label>
                <input type="text" id="address" name="address" required class="form-input" placeholder="123 Smith St, Hamilton" />
              </div>

              <!-- Pet details -->
              <div class="border-t border-[#ede6d4] pt-5">
                <h3 class="font-semibold text-[#2c1a0e] text-sm uppercase tracking-wide mb-3">Pet Details</h3>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="pet-name" class="form-label">Pet's Name <span class="text-red-500">*</span></label>
                    <input type="text" id="pet-name" name="pet_name" required class="form-input" placeholder="Fluffy" />
                  </div>
                  <div>
                    <label for="pet-species" class="form-label">Species <span class="text-red-500">*</span></label>
                    <select id="pet-species" name="pet_species" required class="form-input">
                      <option value="">Select...</option>
                      <option>Dog</option>
                      <option>Cat</option>
                      <option>Rabbit</option>
                      <option>Other</option>
                    </select>
                  </div>
                  <div>
                    <label for="pet-breed" class="form-label">Breed</label>
                    <input type="text" id="pet-breed" name="pet_breed" class="form-input" placeholder="e.g. Labrador, Domestic shorthair" />
                  </div>
                  <div>
                    <label for="pet-age" class="form-label">Age</label>
                    <input type="text" id="pet-age" name="pet_age" class="form-input" placeholder="e.g. 3 years" />
                  </div>
                </div>
              </div>

              <!-- Service -->
              <div class="border-t border-[#ede6d4] pt-5">
                <h3 class="font-semibold text-[#2c1a0e] text-sm uppercase tracking-wide mb-3">Appointment Details</h3>
                <div class="mb-4">
                  <label for="service" class="form-label">Service Required <span class="text-red-500">*</span></label>
                  <select id="service" name="service" required class="form-input">
                    <option value="">Select a service...</option>
                    <option>Routine Consultation ($150)</option>
                    <option>Routine Consultation + additional pet ($250)</option>
                    <option>Vaccinations (add-on, from $40)</option>
                    <option>Recheck ($120)</option>
                    <option>Telemedicine ($80)</option>
                    <option>End-of-Life Care (from $400)</option>
                    <option>Unsure — please advise</option>
                  </select>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  <div>
                    <label for="preferred-date" class="form-label">Preferred Date</label>
                    <input type="date" id="preferred-date" name="preferred_date" class="form-input" />
                  </div>
                  <div>
                    <label for="preferred-time" class="form-label">Preferred Time</label>
                    <select id="preferred-time" name="preferred_time" class="form-input">
                      <option value="">Any time</option>
                      <option>Morning (9am–12pm)</option>
                      <option>Afternoon (12pm–3pm)</option>
                      <option>Late Afternoon (3pm–5pm)</option>
                    </select>
                  </div>
                </div>
              </div>

              <div>
                <label for="notes" class="form-label">Additional Notes</label>
                <textarea id="notes" name="notes" rows="4" class="form-input resize-none" placeholder="Tell us about any concerns, your pet's health history, or anything else we should know..."></textarea>
              </div>

              <div>
                <label for="insurance" class="form-label">Pet Insurance?</label>
                <select id="insurance" name="pet_insurance" class="form-input">
                  <option value="">Select...</option>
                  <option>Yes — I'll claim directly with my provider</option>
                  <option>No pet insurance</option>
                  <option>Not sure</option>
                </select>
              </div>

              <div id="booking-success" class="hidden bg-green-50 border border-green-200 rounded-xl p-4 text-green-800 text-sm">
                <p class="font-semibold mb-1">Booking request received!</p>
                <p>Nicole will be in touch within 24 hours to confirm your appointment. If you need to reach us sooner, call or text <a href="tel:021956242" class="underline">021 956 242</a>.</p>
              </div>
              <div id="booking-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-red-800 text-sm">
                Something went wrong. Please try again or call us on <a href="tel:021956242" class="underline">021 956 242</a>.
              </div>

              <button type="submit" id="booking-submit" class="btn-primary w-full justify-center text-base py-3">
                Request Appointment
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
              <p class="text-xs text-center text-[#6b4c2a]">We'll confirm availability and call to finalise your booking.</p>
            </form>
          </div>
        </div>

      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('booking-form') as HTMLFormElement;
  const success = document.getElementById('booking-success');
  const error = document.getElementById('booking-error');
  const btn = document.getElementById('booking-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' }
      });
      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
        error?.classList.add('hidden');
        success?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      } else {
        throw new Error();
      }
    } catch {
      error?.classList.remove('hidden');
      success?.classList.add('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Request Appointment';
    }
  });
</script>
